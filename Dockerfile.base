FROM python:3.12-slim

RUN apt-get update && apt-get install -y git tesseract-ocr ghostscript && rm -rf /var/lib/apt/lists/*

# CPU-only torch first so marker-pdf doesn't pull CUDA wheels
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu
RUN pip install --no-cache-dir marker-pdf
