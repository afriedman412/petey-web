FROM python:3.12-slim

RUN apt-get update && apt-get install -y git tesseract-ocr ghostscript && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir torch
RUN pip install --no-cache-dir marker-pdf

# Pre-download marker/surya models into the image so cold starts don't fetch them
RUN python -c "from marker.models import create_model_dict; create_model_dict()"
